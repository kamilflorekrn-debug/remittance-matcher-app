<Window x:Class="RemittanceMatcherApp.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ustawienia zaawansowane"
        Height="760" Width="1120" MinHeight="660" MinWidth="980"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="#EEF2F6"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#DCEBFF"/>
            <Setter Property="BorderBrush" Value="#7AA2E3"/>
            <Setter Property="Content" Value="i"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="120"/>
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="ToolTipService.Placement" Value="Mouse"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <Grid>
                <TextBlock Name="CenterHeaderText"
                           Text="GETINGE - REMITTANCE ADVICE MATCHER"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="15"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,14,0">
                    <TextBlock Name="AdvancedHeaderText" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblScoreMin" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="ScoreMinBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtScoreMin" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblScoreMargin" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="ScoreMarginBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtScoreMargin" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblRequireHard" Grid.Column="0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Name="RequireHardBox" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtRequireHard" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblRequireTotalContext" Grid.Column="0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Name="RequireTotalContextBox" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtRequireTotalContext" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblInvoiceRegex" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="InvoiceRegexBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtInvoiceRegex" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblInvoiceWindowLines" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="InvoiceWindowLinesBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtInvoiceWindowLines" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblSingleInvoiceScoreBonus" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="SingleInvoiceScoreBonusBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtSingleInvoiceScoreBonus" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblSingleInvoiceMarginBonus" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="SingleInvoiceMarginBonusBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtSingleInvoiceMarginBonus" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblTotalContextWindowChars" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="TotalContextWindowCharsBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtTotalContextWindowChars" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblStrongNeighborLines" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="StrongNeighborLinesBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtStrongNeighborLines" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblTotalNeighborLines" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="TotalNeighborLinesBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtTotalNeighborLines" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblAllowLooseDigits" Grid.Column="0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Name="AllowLooseDigitsBox" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtAllowLooseDigits" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblMinLooseDigits" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="MinLooseDigitsBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtMinLooseDigits" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblStrongScoreWeight" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="StrongScoreWeightBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtStrongScoreWeight" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblTotalScoreWeight" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="TotalScoreWeightBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtTotalScoreWeight" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblKeywordScoreWeight" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="KeywordScoreWeightBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtKeywordScoreWeight" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblInvoicePenaltyWeight" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Name="InvoicePenaltyWeightBox" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtInvoicePenaltyWeight" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblPreferHardTotal" Grid.Column="0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Name="PreferHardTotalBox" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtPreferHardTotal" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblBlockInvoiceContext" Grid.Column="0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Name="BlockInvoiceContextBox" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}"><Button.ToolTip><TextBlock Name="TtBlockInvoiceContext" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblStrongKeywords" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,0"/>
                        <TextBox Grid.Column="1" Name="StrongKeywordsBox" Margin="8,0,0,0" AcceptsReturn="True" Height="100" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}" VerticalAlignment="Top"><Button.ToolTip><TextBlock Name="TtStrongKeywords" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Name="LblTotalKeywords" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,0"/>
                        <TextBox Grid.Column="1" Name="TotalKeywordsBox" Margin="8,0,0,0" AcceptsReturn="True" Height="100" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" Style="{StaticResource InfoButtonStyle}" VerticalAlignment="Top"><Button.ToolTip><TextBlock Name="TtTotalKeywords" Width="420" TextWrapping="Wrap"/></Button.ToolTip></Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Name="CancelButton" Width="130" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Name="ApplyButton" Width="130" Background="#0B7285" Foreground="White" Click="ApplyButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
