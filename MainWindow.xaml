<Window x:Class="RemittanceMatcherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Getinge Remittance Matcher"
        Height="620" Width="1080" MinHeight="560" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI" FontSize="13"
        Background="#EEF2F6">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0B7285"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1F2937"/>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#DCEBFF"/>
            <Setter Property="BorderBrush" Value="#7AA2E3"/>
            <Setter Property="Content" Value="i"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="120"/>
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="ToolTipService.Placement" Value="Mouse"/>
        </Style>

        <Style x:Key="GreenProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CardBrush}" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Name="CenterHeaderText"
                               Text="GETINGE - REMITTANCE ADVICE MATCHER"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="{StaticResource TextBrush}"/>

                    <DockPanel HorizontalAlignment="Left" LastChildFill="False">
                        <Image Name="AppIconImage" Width="28" Height="28" Stretch="Uniform" Margin="0,0,10,0"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Name="AboutButton" Content="Opis" Width="90" Click="AboutButton_Click" Margin="0"/>
                    </StackPanel>
                </Grid>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,8">
                        <TextBlock Name="LookbackLabelText" Text="Zakres dni wstecz:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <TextBox Name="LookbackDaysBox" Width="90" VerticalContentAlignment="Center"/>
                        <Button Name="LookbackInfoButton" Style="{StaticResource InfoButtonStyle}">
                            <Button.ToolTip>
                                <TextBlock Name="LookbackInfoText" TextWrapping="Wrap" Width="360"/>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>

                    <Button Name="FetchTransactionsButton" Content="Pobierz transakcje" MinWidth="190" Click="FetchTransactionsButton_Click" Margin="0,0,10,8"/>
                    <Button Name="StartButton" Content="Start" MinWidth="140" Click="StartButton_Click" Background="{StaticResource AccentBrush}" Foreground="White" Margin="0,0,10,8"/>
                    <Button Name="StopButton" Content="Stop" MinWidth="140" Click="StopButton_Click" IsEnabled="False" Margin="0,0,0,8"/>
                </WrapPanel>

                <WrapPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Name="SettingsButton" Content="Ustawienia" MinWidth="150" Click="SettingsButton_Click" Margin="0,0,10,0"/>
                    <Button Name="SaveSettingsButton" Content="Zapisz ustawienia" MinWidth="170" Click="SaveSettingsButton_Click" Margin="0,0,10,0"/>
                    <Button Name="LoadSettingsButton" Content="Wczytaj ustawienia" MinWidth="170" Click="LoadSettingsButton_Click" Margin="0,0,10,0"/>
                    <ComboBox Name="LanguageComboBox" Width="140" MinHeight="38" DisplayMemberPath="DisplayName" SelectedValuePath="Code" SelectionChanged="LanguageComboBox_SelectionChanged" VerticalContentAlignment="Center" Margin="0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Name="StatusTextBlock" Text="Gotowe" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <Grid>
                    <ProgressBar Name="RunProgressBar" Style="{StaticResource GreenProgressBarStyle}" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock Name="ProgressPercentText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#111827"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBrush}" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Name="LiveLogLabelText" Grid.Row="0" Text="Log na żywo" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1"
                         Name="LogTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextChanged="LogTextBox_TextChanged"/>
            </Grid>
        </Border>
    </Grid>
</Window>
